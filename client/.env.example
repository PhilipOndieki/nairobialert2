# File: .env.example
# Purpose: Template for required environment variables — copy to .env and fill in your values
# IMPORTANT: Never commit your real .env file. It is gitignored.

# ── Firebase Configuration ────────────────────────────────────────────────────
# Find these values in Firebase Console → Project Settings → Your Apps → Web App
# All VITE_ prefixed vars are exposed to the browser bundle (this is intentional —
# Firebase client SDK keys are not secrets; they are scoped by Firestore security rules).

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
